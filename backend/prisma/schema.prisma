generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_PAYMENT
  CHEQUE
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  PARTIAL
  CANCELLED
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum StockLedgerType {
  IN
  OUT
  ADJUST
}

enum StockLedgerSource {
  PURCHASE
  SALE
  DAMAGE
  RETURN
  ADJUSTMENT
  OPENING
}

enum CustomerLedgerType {
  SALE_DUE
  PAYMENT
  RETURN_ADJUST
  OPENING_BALANCE
}

enum SupplierLedgerType {
  PURCHASE_DUE
  PAYMENT
  RETURN_ADJUST
  OPENING_BALANCE
}

enum CashBookType {
  IN
  OUT
}

enum CashBookSource {
  SALE
  PURCHASE
  EXPENSE
  PAYMENT_RECEIVED
  PAYMENT_MADE
  BANK_DEPOSIT
  BANK_WITHDRAW
  OPENING
  OTHER
}

enum BankTransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER_IN
  TRANSFER_OUT
}
enum ConversionSign {
  MULTIPLY
  DIVIDE
}

// ==================== AUTH & USERS ====================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  isActive      Boolean   @default(true)
  refreshToken  String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userRoles     UserRole[]
  userBranches  UserBranch[]
  sales         Sale[]
  purchases     Purchase[]
  createdCustomers Customer[] @relation("CreatedByUser")
  createdSuppliers Supplier[] @relation("CreatedByUser")
  stockLedgers  StockLedger[] @relation("StockLedgerCreatedBy") 


  @@index([email])
  @@index([deletedAt])
}

model Branch {
  id          String    @id @default(uuid())
  name        String
  code        String    @unique
  phone       String?
  address     String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userBranches UserBranch[]
  customers    Customer[]
  suppliers    Supplier[]
  stockLedgers StockLedger[]
  purchases    Purchase[]
  sales        Sale[]
  returns      Return[]
  estimates    Estimate[]
  damages      Damage[]
  expenses     Expense[]
  payments     Payment[]
  bankAccounts BankAccount[]
  employees    Employee[]
  assets       Asset[]
  cashBooks    CashBook[]

  @@index([code])
  @@index([deletedAt])
}

model UserBranch {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([branchId])
}

model Role {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  isSystem    Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([name])
}

model Permission {
  id          String    @id @default(uuid())
  key         String    @unique
  name        String
  description String?
  module      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rolePermissions RolePermission[]

  @@index([key])
  @@index([module])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// ==================== BUSINESS ENTITIES ====================

model Owner {
  id          String    @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  nid         String?
  image       String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([deletedAt])
}

model Unit {
  id        String   @id @default(uuid())
  name      String   @unique
  shortName String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  products Product[]

  conversion UnitConversion? @relation("UnitToConversion")

  relatedConversions UnitConversion[] @relation("RelatedToUnit")
}

model UnitConversion {
  id          String  @id @default(uuid())
  unitId      String  @unique
  relatedToId String
  sign        String  @default("*")
  factor      Decimal @db.Decimal(12, 4)

  // the unit being converted (Dozen, Kg, Litre)
  unit Unit @relation("UnitToConversion", fields: [unitId], references: [id], onDelete: Cascade)

  //  base unit (pc, gm, ml)
  relatedTo Unit @relation("RelatedToUnit", fields: [relatedToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([relatedToId])
}



model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  image       String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([name])
  @@index([deletedAt])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String?   @unique
  description String?
  image       String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subcategories Subcategory[]
  products      Product[]

  @@index([name])
  @@index([code])
  @@index([deletedAt])
}

model Subcategory {
  id          String    @id @default(uuid())
  name        String
  code        String?   @unique
  description String?
  categoryId  String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category Category  @relation(fields: [categoryId], references: [id])
  products Product[]

  @@unique([categoryId, name])
  @@index([name])
  @@index([deletedAt])
}

// ==================== PRODUCTS & STOCK ====================

model Product {
  id             String    @id @default(uuid())
  name           String
  productCode    String    @unique
  barcode        String?   @unique
  description    String?
  costPrice      Decimal   @db.Decimal(12, 2)
  sellPrice      Decimal   @db.Decimal(12, 2)
  alertQuantity  Int       @default(10)
  image          String?
  categoryId     String?
  subcategoryId  String?
  brandId        String?
  unitId         String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  category      Category?     @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory?  @relation(fields: [subcategoryId], references: [id])
  brand         Brand?        @relation(fields: [brandId], references: [id])
  unit          Unit?         @relation(fields: [unitId], references: [id])
  
  stockLedger   StockLedger[]
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  damageItems   DamageItem[]
  returnItems   ReturnItem[]

  @@index([productCode])
  @@index([barcode])
  @@index([name])
  @@index([deletedAt])
}

model StockLedger {
  id          String            @id @default(uuid())
  productId   String
  branchId    String?
  type        StockLedgerType
  source      StockLedgerSource
  referenceId String?
  quantity    Int
  note        String?
  createdAt   DateTime          @default(now())

  createdById String?
createdBy   User? @relation("StockLedgerCreatedBy", fields: [createdById], references: [id])

  product     Product           @relation(fields: [productId], references: [id])
  branch      Branch?           @relation(fields: [branchId], references: [id])

  @@index([productId])
  @@index([branchId])
  @@index([source])
  @@index([createdAt])
  @@index([createdById])
}


// ==================== SUPPLIERS ====================

model Supplier {
  id              String    @id @default(uuid())
  name            String
  email           String?
  phone           String?
  address         String?
  company         String?
  openingBalance  Decimal   @default(0) @db.Decimal(12, 2)
  createdById     String?
  branchId        String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdBy       User?            @relation("CreatedByUser", fields: [createdById], references: [id])
  branch          Branch?          @relation(fields: [branchId], references: [id])
  purchases       Purchase[]
  supplierLedger  SupplierLedger[]
  supplierPayments SupplierPayment[]

  @@index([name])
  @@index([phone])
  @@index([deletedAt])
  @@index([branchId])
}

model SupplierLedger {
  id          String             @id @default(uuid())
  supplierId  String
  type        SupplierLedgerType
  referenceId String?
  amount      Decimal            @db.Decimal(12, 2)
  balance     Decimal            @db.Decimal(12, 2)
  note        String?
  createdAt   DateTime           @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([createdAt])
}

model SupplierPayment {
  id            String        @id @default(uuid())
  supplierId    String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  note          String?
  paymentDate   DateTime      @default(now())
  createdAt     DateTime      @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([paymentDate])
}

// ==================== CUSTOMERS ====================

model Customer {
  id              String    @id @default(uuid())
  name            String
  email           String?
  phone           String?
  address         String?
  company         String?
  openingBalance  Decimal   @default(0) @db.Decimal(12, 2)
  createdById     String?
  branchId        String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdBy       User?            @relation("CreatedByUser", fields: [createdById], references: [id])
  branch          Branch?          @relation(fields: [branchId], references: [id])
  sales           Sale[]
  customerLedger  CustomerLedger[]
  customerPayments CustomerPayment[]
  estimates       Estimate[]

  @@index([name])
  @@index([phone])
  @@index([deletedAt])
  @@index([branchId])
}

model CustomerLedger {
  id          String             @id @default(uuid())
  customerId  String
  type        CustomerLedgerType
  referenceId String?
  amount      Decimal            @db.Decimal(12, 2)
  balance     Decimal            @db.Decimal(12, 2)
  note        String?
  createdAt   DateTime           @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdAt])
}

model CustomerPayment {
  id            String        @id @default(uuid())
  customerId    String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  note          String?
  paymentDate   DateTime      @default(now())
  createdAt     DateTime      @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([paymentDate])
}

// ==================== PURCHASES ====================

model Purchase {
  id              String         @id @default(uuid())
  invoiceNo       String         @unique
  supplierId      String
  branchId        String?
  userId          String?
  subtotal        Decimal        @db.Decimal(12, 2)
  discount        Decimal        @default(0) @db.Decimal(12, 2)
  tax             Decimal        @default(0) @db.Decimal(12, 2)
  shippingCost    Decimal        @default(0) @db.Decimal(12, 2)
  total           Decimal        @db.Decimal(12, 2)
  paidAmount      Decimal        @default(0) @db.Decimal(12, 2)
  dueAmount       Decimal        @db.Decimal(12, 2)
  status          PurchaseStatus @default(PENDING)
  paymentStatus   PaymentStatus  @default(PENDING)
  note            String?
  purchaseDate    DateTime       @default(now())
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id])
  user          User?          @relation(fields: [userId], references: [id])
  purchaseItems PurchaseItem[]
  payments      Payment[]      @relation("PurchasePayments")

  @@index([invoiceNo])
  @@index([supplierId])
  @@index([branchId])
  @@index([purchaseDate])
  @@index([deletedAt])
}

model PurchaseItem {
  id          String  @id @default(uuid())
  purchaseId  String
  productId   String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}

// ==================== SALES ====================

model Sale {
  id              String        @id @default(uuid())
  invoiceNo       String        @unique
  customerId      String?
  branchId        String?
  userId          String?
  subtotal        Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  discountType    String?       @default("fixed")
  tax             Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)
  dueAmount       Decimal       @db.Decimal(12, 2)
  changeAmount    Decimal       @default(0) @db.Decimal(12, 2)
  status          SaleStatus    @default(COMPLETED)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(CASH)
  note            String?
  saleDate        DateTime      @default(now())
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer   Customer?   @relation(fields: [customerId], references: [id])
  branch     Branch?     @relation(fields: [branchId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])
  saleItems  SaleItem[]
  payments   Payment[]   @relation("SalePayments")
  returns    Return[]

  @@index([invoiceNo])
  @@index([customerId])
  @@index([branchId])
  @@index([saleDate])
  @@index([deletedAt])
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// ==================== RETURNS ====================

model Return {
  id          String    @id @default(uuid())
  returnNo    String    @unique
  saleId      String
  branchId    String?
  total       Decimal   @db.Decimal(12, 2)
  note        String?
  returnDate  DateTime  @default(now())
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sale        Sale         @relation(fields: [saleId], references: [id])
  branch      Branch?      @relation(fields: [branchId], references: [id])
  returnItems ReturnItem[]

  @@index([returnNo])
  @@index([saleId])
  @@index([branchId])
  @@index([deletedAt])
}

model ReturnItem {
  id        String  @id @default(uuid())
  returnId  String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  return  Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([returnId])
  @@index([productId])
}

// ==================== ESTIMATES ====================

model Estimate {
  id            String    @id @default(uuid())
  estimateNo    String    @unique
  customerId    String?
  branchId      String?
  subtotal      Decimal   @db.Decimal(12, 2)
  discount      Decimal   @default(0) @db.Decimal(12, 2)
  tax           Decimal   @default(0) @db.Decimal(12, 2)
  total         Decimal   @db.Decimal(12, 2)
  note          String?
  validUntil    DateTime?
  estimateDate  DateTime  @default(now())
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer      Customer?      @relation(fields: [customerId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id])
  estimateItems EstimateItem[]

  @@index([estimateNo])
  @@index([customerId])
  @@index([branchId])
  @@index([deletedAt])
}

model EstimateItem {
  id          String  @id @default(uuid())
  estimateId  String
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

// ==================== DAMAGES ====================

model Damage {
  id         String    @id @default(uuid())
  damageNo   String    @unique
  total      Decimal   @db.Decimal(12, 2)
  branchId   String?
  note       String?
  damageDate DateTime  @default(now())
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  damageItems DamageItem[]
  branch      Branch?      @relation(fields: [branchId], references: [id])

  @@index([damageNo])
  @@index([deletedAt])
  @@index([branchId])
}

model DamageItem {
  id        String  @id @default(uuid())
  damageId  String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  damage  Damage  @relation(fields: [damageId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([damageId])
  @@index([productId])
}

// ==================== EXPENSES ====================

model ExpenseCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  expenses Expense[]

  @@index([name])
  @@index([deletedAt])
}

model Expense {
  id                String        @id @default(uuid())
  expenseCategoryId String
  branchId          String?
  bankAccountId     String?
  amount            Decimal       @db.Decimal(12, 2)
  paymentMethod     PaymentMethod @default(CASH)
  description       String?
  reference         String?
  expenseDate       DateTime      @default(now())
  deletedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  expenseCategory ExpenseCategory @relation(fields: [expenseCategoryId], references: [id])
  branch          Branch?         @relation(fields: [branchId], references: [id])
  bankAccount     BankAccount?    @relation(fields: [bankAccountId], references: [id])

  @@index([expenseCategoryId])
  @@index([expenseDate])
  @@index([deletedAt])
  @@index([branchId])
}

// ==================== PAYMENTS ====================

model Payment {
  id            String        @id @default(uuid())
  saleId        String?
  branchId      String?
  purchaseId    String?
  customerId    String?
  supplierId    String?
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  note          String?
  paymentDate   DateTime      @default(now())
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sale     Sale?     @relation("SalePayments", fields: [saleId], references: [id])
  purchase Purchase? @relation("PurchasePayments", fields: [purchaseId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])

  @@index([saleId])
  @@index([purchaseId])
  @@index([paymentDate])
  @@index([deletedAt])
  @@index([branchId])
}

// ==================== BANK ACCOUNTS ====================

model BankAccount {
  id              String    @id @default(uuid())
  bankName        String
  accountName     String
  accountNumber   String    @unique
  branchId         String?
  branch          String?
  openingBalance  Decimal   @default(0) @db.Decimal(12, 2)
  currentBalance  Decimal   @default(0) @db.Decimal(12, 2)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    BankTransaction[]
  expenses        Expense[]
  branchInfo      Branch?           @relation(fields: [branchId], references: [id])

  @@index([accountNumber])
  @@index([deletedAt])
  @@index([branchId])
}

model BankTransaction {
  id              String              @id @default(uuid())
  bankAccountId   String
  type            BankTransactionType
  amount          Decimal             @db.Decimal(12, 2)
  balanceAfter    Decimal             @db.Decimal(12, 2)
  referenceId     String?
  description     String?
  transactionDate DateTime            @default(now())
  createdAt       DateTime            @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([bankAccountId])
  @@index([transactionDate])
}

// ==================== EMPLOYEES & SALARY ====================

model Employee {
  id           String    @id @default(uuid())
  name         String
  branchId     String?
  email        String?
  phone        String?
  address      String?
  nid          String?
  designation  String?
  department   String?
  joinDate     DateTime  @default(now())
  basicSalary  Decimal   @default(0) @db.Decimal(12, 2)
  image        String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  salaryPayments SalaryPayment[]
  branch         Branch?          @relation(fields: [branchId], references: [id])

  @@index([name])
  @@index([phone])
  @@index([deletedAt])
  @@index([branchId])
}

model SalaryPayment {
  id            String        @id @default(uuid())
  employeeId    String
  basicSalary   Decimal       @db.Decimal(12, 2)
  overtime      Decimal       @default(0) @db.Decimal(12, 2)
  bonus         Decimal       @default(0) @db.Decimal(12, 2)
  deduction     Decimal       @default(0) @db.Decimal(12, 2)
  netSalary     Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  month         Int
  year          Int
  note          String?
  paymentDate   DateTime      @default(now())
  createdAt     DateTime      @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([paymentDate])
}

// ==================== ASSETS ====================

model Asset {
  id              String    @id @default(uuid())
  name            String
  branchId        String?
  description     String?
  purchasePrice   Decimal   @db.Decimal(12, 2)
  currentValue    Decimal   @db.Decimal(12, 2)
  purchaseDate    DateTime
  location        String?
  serialNumber    String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  branch          Branch?   @relation(fields: [branchId], references: [id])

  @@index([name])
  @@index([deletedAt])
  @@index([branchId])
}

// ==================== CASH BOOK ====================

model CashBook {
  id          String         @id @default(uuid())
  branchId    String?
  type        CashBookType
  source      CashBookSource
  referenceId String?
  amount      Decimal        @db.Decimal(12, 2)
  balance     Decimal        @db.Decimal(12, 2)
  description String?
  entryDate   DateTime       @default(now())
  createdAt   DateTime       @default(now())
  branch      Branch?        @relation(fields: [branchId], references: [id])

  @@index([entryDate])
  @@index([source])
  @@index([branchId])
}

// ==================== SETTINGS ====================

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}
